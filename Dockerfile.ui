# Dockerfile for Streamlit Dashboard UI
FROM python:3.11-slim

# Set metadata
LABEL maintainer="PicoClaw Finance Agent"
LABEL version="1.0"
LABEL description="PicoClaw Finance Agent - Streamlit Dashboard UI"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0 \
    STREAMLIT_SERVER_HEADLESS=true \
    STREAMLIT_CLIENT_LOGGER_LEVEL=info \
    STREAMLIT_LOGGER_LEVEL=info

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create app user
RUN useradd -m -s /bin/bash appuser

# Set working directory
WORKDIR /app

# Copy requirements files
COPY requirements.txt requirements_ui.txt ./

# Install Python dependencies
RUN pip install --upgrade pip && \
    pip install -r requirements.txt && \
    pip install -r requirements_ui.txt

# Copy application code
COPY finance_service/ ./finance_service/
COPY tests/ ./tests/

# Create Streamlit config directory
RUN mkdir -p /home/appuser/.streamlit && \
    chown -R appuser:appuser /app /home/appuser

# Create Streamlit config file
RUN echo '[client]\nshowErrorDetails = true\n[logger]\nlevel = info\n[server]\nport = 8501\n' > /home/appuser/.streamlit/config.toml

# Switch to app user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# Expose port
EXPOSE 8501

# Run Streamlit app
CMD ["streamlit", "run", "finance_service/ui/dashboard.py", "--logger.level=info", "--client.showErrorDetails=true"]
