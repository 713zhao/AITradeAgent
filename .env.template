# PicoClaw Finance Agent - Environment Configuration Template
# Copy this file to .env and customize for your environment
# DO NOT COMMIT .env to version control!

# ========================
# Flask/App Configuration
# ========================
FLASK_ENV=production
FLASK_DEBUG=false
PICOTRADEAGENT_ENV=production
PYTHONUNBUFFERED=1
LOG_LEVEL=info

# ========================
# Redis Configuration
# ========================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========================
# Database Configuration
# ========================
DATABASE_URL=sqlite:////app/finance_service/storage/finance.db
DB_PATH=/app/finance_service/storage

# ========================
# API Configuration
# ========================
API_HOST=0.0.0.0
API_PORT=5000
API_WORKERS=4
API_TIMEOUT=30
API_RATE_LIMIT=100/hour

# ========================
# Trading Configuration
# ========================
# Broker credentials (keep secure!)
BROKER_API_KEY=your_broker_api_key
BROKER_API_SECRET=your_broker_api_secret
BROKER_ACCOUNT_ID=your_account_id

# Trading parameters
MIN_POSITION_SIZE=100
MAX_POSITION_SIZE=10000
MAX_DAILY_TRADES=50
RISK_LIMIT_PERCENT=2

# ========================
# Streamlit Configuration
# ========================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_LOGGER_LEVEL=info
STREAMLIT_LOGGER_LEVEL=info
API_BASE_URL=http://picotradeagent:5000

# ========================
# Nginx Configuration
# ========================
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_WORKER_PROCESSES=4

# ========================
# Monitoring Configuration
# ========================
PROMETHEUS_RETENTION=30d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin  # Change in production!

# ========================
# SSL/TLS Configuration
# ========================
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/certs/finance-agent.crt
SSL_KEY_PATH=/etc/nginx/ssl/private/finance-agent.key

# ========================
# Alerting Configuration
# ========================
ALERT_EMAIL=admin@example.com
ALERT_WEBHOOK_URL=
ALERT_ENABLED=true

# ========================
# Performance Tuning
# ========================
WORKER_THREADS=4
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30
CACHE_TIMEOUT=300

# ========================
# Feature Flags
# ========================
ENABLE_WEBSOCKET=false
ENABLE_ML_MODELS=false
ENABLE_PAPER_TRADING=true
ENABLE_BACKTESTING=true

# ========================
# Volume Paths
# ========================
STORAGE_PATH=/app/finance_service/storage
LOGS_PATH=/app/logs
BACKUPS_PATH=/app/backups

# ========================
# Security
# ========================
# Generate with: openssl rand -base64 32
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
SESSION_TIMEOUT=3600

# ========================
# Notification Services
# ========================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
