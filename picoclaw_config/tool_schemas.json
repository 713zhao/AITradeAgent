[
  {
    "name": "data_agent_fetch",
    "description": "Data Agent: Fetch cached or fresh OHLCV market data for symbols",
    "parameters": {
      "type": "object",
      "properties": {
        "symbols": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Stock symbols to fetch (e.g., ['NVDA', 'MSFT'])"
        },
        "timeframe": {
          "type": "string",
          "enum": ["15m", "1h", "1d"],
          "description": "Timeframe: 15m, 1h, or 1d"
        },
        "lookback_days": {
          "type": "integer",
          "description": "Days of history (default 365)",
          "default": 365
        }
      },
      "required": ["symbols", "timeframe"]
    }
  },
  {
    "name": "analysis_agent_indicators",
    "description": "Analysis Agent: Calculate technical indicators (SMA, RSI, MACD, ATR)",
    "parameters": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock symbol"
        },
        "timeframe": {
          "type": "string",
          "enum": ["15m", "1h", "1d"],
          "description": "Timeframe"
        }
      },
      "required": ["symbol", "timeframe"]
    }
  },
  {
    "name": "strategy_agent_decide",
    "description": "Strategy Agent: Generate trading signal (BUY/SELL/HOLD) with confidence",
    "parameters": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock symbol"
        },
        "timeframe": {
          "type": "string",
          "enum": ["15m", "1h", "1d"],
          "description": "Timeframe"
        }
      },
      "required": ["symbol", "timeframe"]
    }
  },
  {
    "name": "risk_agent_validate",
    "description": "Risk Agent: Validate and size trade proposal",
    "parameters": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock symbol"
        },
        "side": {
          "type": "string",
          "enum": ["BUY", "SELL", "HOLD"],
          "description": "Trade direction"
        },
        "confidence": {
          "type": "number",
          "description": "Strategy confidence (0-1)"
        },
        "timeframe": {
          "type": "string",
          "enum": ["15m", "1h", "1d"],
          "description": "Timeframe"
        }
      },
      "required": ["symbol", "side", "confidence", "timeframe"]
    }
  },
  {
    "name": "execution_agent_paper_trade",
