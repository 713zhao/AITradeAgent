      "properties": {
        "symbol": {
          "type": "string"
        },
        "side": {
          "type": "string",
          "enum": ["BUY", "SELL"]
        },
        "qty": {
          "type": "integer"
        },
        "timeframe": {
          "type": "string",
          "enum": ["15m", "1h", "1d"]
        },
        "reason": {
          "type": "string",
          "description": "Trade rationale"
        }
      },
      "required": ["symbol", "side", "qty", "timeframe"]
    }
  },
  {
    "name": "learning_agent_run",
    "description": "Learning Agent: Run backtest/optimization",
    "parameters": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["dry_run", "apply_if_better"],
          "default": "dry_run"
