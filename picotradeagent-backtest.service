[Unit]
Description=PicoClaw Finance Agent Backtest Job
After=picotradeagent.service
Requires=picotradeagent.service

[Service]
Type=oneshot
User=eric
WorkingDirectory=/home/eric/.picoclaw/workspace/picotradeagent
Environment="PATH=/home/eric/.picoclaw/workspace/picotradeagent/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
Environment="PYTHONUNBUFFERED=1"

ExecStart=/home/eric/.picoclaw/workspace/picotradeagent/venv/bin/python -m \
    finance_service.tools.backtest \
    --symbols AAPL MSFT TSLA SPY QQQ \
    --lookback 252 \
    --output /home/eric/.picoclaw/workspace/picotradeagent/backtest_results.json

StandardOutput=journal
StandardError=journal
SyslogIdentifier=picotradeagent-backtest
