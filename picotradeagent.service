[Unit]
Description=PicoClaw Finance Agent Service
Documentation=https://github.com/picoclaw/picotradeagent
After=network.target
Wants=picotradeagent-backtest.timer

[Service]
Type=simple
User=eric
WorkingDirectory=/home/eric/.picoclaw/workspace/picotradeagent
Environment="PATH=/home/eric/.picoclaw/workspace/picotradeagent/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
Environment="PYTHONUNBUFFERED=1"
Environment="PICOTRADEAGENT_ENV=production"
Environment="FLASK_ENV=production"
Environment="FLASK_APP=finance_service.app:app"

# Service execution
ExecStartPre=/bin/bash -c 'mkdir -p /var/log/picotradeagent /var/run/picotradeagent'
ExecStart=/home/eric/.picoclaw/workspace/picotradeagent/venv/bin/python -m gunicorn \
    -w 4 \
    -b 127.0.0.1:5000 \
    -t 120 \
    --access-logfile /var/log/picotradeagent/access.log \
    --error-logfile /var/log/picotradeagent/error.log \
    --log-level info \
    finance_service.app:app

# Restart policy
Restart=on-failure
RestartSec=10s
StartLimitInterval=60s
StartLimitBurst=3

# Security
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/eric/.picoclaw/workspace/picotradeagent/finance_service/storage \
              /var/log/picotradeagent \
              /var/run/picotradeagent

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
